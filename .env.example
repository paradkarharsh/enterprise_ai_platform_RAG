# ==============================================================================
# Master Environment Variables Example for Manthan AI - Enterprise Knowledge Intelligence Platform
# Copy this to .env (or specific .env files in backend/ and frontend/) and customize.
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. Application Settings
# ------------------------------------------------------------------------------
ENVIRONMENT=development
DEBUG=true
APP_NAME="Manthan AI — Enterprise Knowledge Intelligence Platform"
APP_VERSION=1.0.0
API_PREFIX=/api/v1
SECRET_KEY=change-this-in-production-use-openssl-rand-hex-32
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000", "http://localhost:3001"]

# ------------------------------------------------------------------------------
# 2. Database - PostgreSQL
# ------------------------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=enterprise_ai
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ------------------------------------------------------------------------------
# 3. Redis Cache & Celery Broker
# ------------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ------------------------------------------------------------------------------
# 4. Neo4j Knowledge Graph
# ------------------------------------------------------------------------------
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j_password

# ------------------------------------------------------------------------------
# 5. AI Providers (API Keys)
# ------------------------------------------------------------------------------
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OLLAMA_BASE_URL=http://localhost:11434

# ------------------------------------------------------------------------------
# 6. LLM & Embedding Settings
# ------------------------------------------------------------------------------
DEFAULT_LLM_PROVIDER=gemini
DEFAULT_LLM_MODEL=gemini-2.0-flash
DEFAULT_EMBEDDING_PROVIDER=gemini
DEFAULT_EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1024

# ------------------------------------------------------------------------------
# 7. Vector Stores
# ------------------------------------------------------------------------------
DEFAULT_VECTOR_STORE=chroma
CHROMA_HOST=localhost
CHROMA_PORT=8100
CHROMA_COLLECTION=enterprise_knowledge

# Optional: Pinecone Vector Store
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX=enterprise-knowledge
PINECONE_ENVIRONMENT=us-east-1

# Optional: Weaviate Vector Store
WEAVIATE_URL=http://localhost:8080
WEAVIATE_API_KEY=your_weaviate_api_key_here

# Local FAISS index path
FAISS_INDEX_PATH=./data/faiss_index

# ------------------------------------------------------------------------------
# 8. JWT Authentication
# ------------------------------------------------------------------------------
JWT_SECRET_KEY=jwt-secret-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ------------------------------------------------------------------------------
# 9. OAuth Authentication (Google & GitHub)
# ------------------------------------------------------------------------------
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here
OAUTH_REDIRECT_URI=http://localhost:3000/auth/callback

# ------------------------------------------------------------------------------
# 10. Rate Limiting
# ------------------------------------------------------------------------------
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# ------------------------------------------------------------------------------
# 11. Ingestion Settings
# ------------------------------------------------------------------------------
MAX_UPLOAD_SIZE_MB=100
UPLOAD_DIR=./uploads
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# ------------------------------------------------------------------------------
# 12. Frontend Configurations
# ------------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000
