# ==============================================================================
# Master .gitignore for Enterprise AI Knowledge Platform
# Covers Python (Backend), Node/Next.js (Frontend), and Infra
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. Environment variables & Secrets
# ------------------------------------------------------------------------------
.env
.env.local
.env.development
.env.development.local
.env.test.local
.env.production.local
*.env
*.env.*
!.env.example
!*.env.example
*.pem
*.key
*.cert
secrets.json

# ------------------------------------------------------------------------------
# 2. Python / Backend
# ------------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
venv/
.venv/
ENV/
env/
active_env/
PIPENV_VENV_IN_PROJECT/
.poetry/

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/
pytestdebug.log

# Static Analysis
.mypy_cache/
.ruff_cache/
.pylint.d/

# Logs and databases
*.log
*.sqlite3
celerybeat-schedule
celerybeat.pid

# ------------------------------------------------------------------------------
# 3. Node / Frontend (Next.js)
# ------------------------------------------------------------------------------
node_modules/
jspm_packages/
web_modules/
.pnp
.pnp.js
.pnpm-store/

# Next.js build output
.next/
out/
build/
dist/

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Testing
coverage/
.nyc_output/

# Cache
.eslintcache
.stylelintcache
*.tsbuildinfo

# Vercel
.vercel

# ------------------------------------------------------------------------------
# 4. Data & Uploads (App specific)
# ------------------------------------------------------------------------------
# Ignore all local db storage, indexes, and uploaded files
data/db/
data/faiss_index/
data/chroma/
backend/data/faiss_index/
backend/data/chroma/
backend/uploads/
uploads/

# ------------------------------------------------------------------------------
# 5. IDEs and Editors
# ------------------------------------------------------------------------------
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.project
.classpath
.settings/
.cursor/

# ------------------------------------------------------------------------------
# 6. Operating System Files
# ------------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
ehthumbs_vista.db
[Tt]humbs.db
Desktop.ini
